# Postgres connection string.
#
# Neon: copy the *pooled* connection string from your project dashboard
# (Connect → Connection pooling on; the host contains "-pooler").
# It looks like:
#   postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
#
# Any other Postgres works too, e.g. a local one:
#   postgres://flinder@localhost:5432/flinder
DATABASE_URL=
